# ────────────────────────────────────────────────────────────────────
# MoodEats Backend — Environment Variables
# ────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)
# ────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string from Supabase (or any Postgres provider)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/moodeats"

# ─── Server ───────────────────────────────────────────────────────
# Port the backend listens on (hosting platforms set this automatically)
PORT=5500

# Environment: "development" or "production"
# In production: error messages are generic (no stack traces leaked)
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────
# The URL of your frontend (used to restrict which origins can call the API)
# Development: http://localhost:5173 (Vite default)
# Production: https://your-deployed-frontend.com
FRONTEND_URL="http://localhost:5173"

# ─── External APIs ───────────────────────────────────────────────
# Google Places API key (for restaurant search)
# Get one at: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Restrict this key to your domain in the Google Console!
GOOGLE_API_KEY="your-google-api-key-here"

# ─── Session Config (optional, defaults shown) ────────────────────
# How long sessions last before expiring (in hours)
# SESSION_EXPIRY_HOURS=24
