/*
Whenever you add new tables/columns later, you'll need to:

Update schema.prisma

Manually run the SQL in Supabase's SQL Editor

Run npx prisma generate
*/


generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  nameFirst String
  nameLast  String
  email     String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  token     String   @id
  userId    Int
  nameFirst String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}